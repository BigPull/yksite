# ============================================================
#  YKsystems – Umgebungskonfiguration
#  Kopiere diese Datei zu ".env" und passe die Werte an.
#  NIEMALS die echte .env committen.
# ============================================================

# --- Datenbank (PostgreSQL im Docker-Container) ---
POSTGRES_USER=yksystems
POSTGRES_PASSWORD=bitte_aendern_sicheres_passwort
POSTGRES_DB=yksystems
# Verbindungs-URL für Prisma (Host "db" = Service-Name in docker-compose)
DATABASE_URL=postgresql://yksystems:bitte_aendern_sicheres_passwort@db:5432/yksystems?schema=public

# --- Admin-Initialzugang (nur beim ersten Start verwendet) ---
ADMIN_EMAIL=admin@yk-systems.de
ADMIN_PASSWORD=bitte_aendern_starkes_admin_passwort

# --- Session / Auth ---
# Langer, zufälliger Wert. Erzeugen z.B. mit:  openssl rand -base64 48
SESSION_SECRET=bitte_durch_langen_zufallswert_ersetzen_min_32_zeichen

# --- Laufzeit ---
NODE_ENV=production
# Verzeichnis für hochgeladene Bilder (im Container, gemappt auf ./uploads)
UPLOAD_DIR=/app/uploads

# --- E-Mail-Versand der Anfragen (SMTP, optional) ---
# Empfänger der Konfigurator-Anfragen
INQUIRY_RECIPIENT=kontakt@yk-systems.de
# Wenn SMTP_HOST leer ist, werden Anfragen nur in der DB gespeichert (kein Mailversand).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=YKsystems <kontakt@yk-systems.de>
